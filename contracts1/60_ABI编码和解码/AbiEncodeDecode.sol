pragma solidity ^0.8.3;

contract AbiEncodeDecode{
    struct TestStruct{
        string name;
        uint[2] marks;
    }
 
//编码  5  0x5B38Da6a701c568545dCfcB03FcB875f56beddC4   [5,6]  ["he",[1,2]]   //参数不能太长
    function encode(uint x, address addr,uint[] calldata arr,TestStruct memory ts) public pure returns(bytes memory){
        return abi.encode(x,addr,arr,ts);
    }
// 解码  
// 0:uint256: 5
// 1:address: 0x5B38Da6a701c568545dCfcB03FcB875f56beddC4
// 2:uint256[]: 5,6
// 3:tuple(string,uint256[2]): he,1,2 
    function decode(bytes memory encodedData) public pure returns(uint,address,uint[] memory,TestStruct memory){
        (uint x,address addr,uint[] memory arr,TestStruct memory ts) = abi.decode(encodedData,(uint,address,uint[],TestStruct));
        return (x,addr,arr,ts);
    }
}